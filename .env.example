# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# PostgreSQL database
DB_NAME=videoflix
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (used by Django RQ for background tasks and as cache backend)
# In Docker set REDIS_HOST=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Email (default: console backend prints emails to the terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@videoflix.local

# Base URL of the frontend for activation and password-reset links
FRONTEND_URL=http://localhost:4200

# CORS / CSRF — comma-separated origins of the frontend that may call the API.
# Cookies are sent cross-origin, so these must be explicit (no "*").
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:5500,http://127.0.0.1:5500
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:5500,http://127.0.0.1:5500
